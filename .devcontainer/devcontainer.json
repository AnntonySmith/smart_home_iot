{
    "name": "Smart Home IoT Project",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    },
    "postCreateCommand": "pip install -r requirements.txt",
    "forwardPorts": [5000],
    "portsAttributes": {
        "5000": {
            "label": "Flask Application",
            "onAutoForward": "notify"
        }
    }
}
